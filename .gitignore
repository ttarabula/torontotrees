data/raw/
# Ignore data/processed/ contents but keep the directory itself navigable so
# the negation patterns below can re-include specific files.
data/processed/*
# Exception: the 4 LiDAR-derived nbhd parquets are tiny (~95 KB total) and
# rarely change (source LiDAR updates every ~5 years). Commit them so CI can
# rebuild /neighbourhoods/ pages without needing the multi-GB LiDAR GDB.
!data/processed/nbhd_canopy.parquet
!data/processed/nbhd_canopy_change.parquet
!data/processed/nbhd_heat.parquet
!data/processed/nbhd_value.parquet
# site/ HTML is committed; per-street and per-species JSON are generated by CI
site/data/street/
site/data/streets.json
site/data/species/
site/data/species_index.json
site/data/near/
.DS_Store
